generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Auth (NextAuth 호환 테이블)
// ─────────────────────────────────────────────────────────────

enum UserRole {
  USER
  OWNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  password      String?
  phone         String?    @unique
  image         String?
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts      Account[]
  sessions      Session[]
  cars          Car[]
  reservations  Reservation[]
  favorites     Favorite[]
  coupons       Coupon[]
  reviews       Review[]
  passSub       PassSubscription?
  ownedStores   Store[]   @relation("StoreOwner")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────
// Domain
// ─────────────────────────────────────────────────────────────

model Car {
  id        String   @id @default(cuid())
  userId    String
  brand     String
  model     String
  plate     String
  color     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([userId])
  @@map("cars")
}

model Store {
  id          String   @id @default(cuid())
  ownerId     String?
  name        String
  address     String
  phone       String?
  lat         Float?
  lng         Float?
  coverImages Json     @default("[]")
  hours       Json     @default("{}")
  services    String[] @default([])
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  open        Boolean  @default(true)
  promo       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User?         @relation("StoreOwner", fields: [ownerId], references: [id])
  products     Product[]
  reservations Reservation[]
  favorites    Favorite[]
  reviews      Review[]
  closedDays   StoreClosedDay[]

  @@index([ownerId])
  @@map("stores")
}

model StoreClosedDay {
  id      String   @id @default(cuid())
  storeId String
  date    DateTime @db.Date
  reason  String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@map("store_closed_days")
}

enum ProductType {
  SELF
  HAND
  PICKUP
  VISIT
  PREMIUM
}

model Product {
  id          String      @id @default(cuid())
  storeId     String
  type        ProductType
  title       String
  subtitle    String?
  description String?     @db.Text
  durationMin Int
  price       Int
  images      Json        @default("[]")
  options     Json        @default("[]")
  cautions    String[]    @default([])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([storeId])
  @@map("products")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  DONE
  CANCELED
}

model Reservation {
  id          String            @id @default(cuid())
  userId      String
  storeId     String
  productId   String
  carId       String?
  startAt     DateTime
  durationMin Int
  price       Int
  options     Json              @default("[]")
  request     String?           @db.Text
  status      ReservationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  store       Store         @relation(fields: [storeId], references: [id])
  product     Product       @relation(fields: [productId], references: [id])
  car         Car?          @relation(fields: [carId], references: [id])
  payment     Payment?
  review      Review?
  beforeAfter BeforeAfter?

  @@index([userId])
  @@index([storeId])
  @@index([startAt])
  @@map("reservations")
}

enum PaymentMethod {
  EASY
  CARD
}

enum PaymentStatus {
  PENDING
  DONE
  FAILED
  REFUNDED
}

model Payment {
  id             String        @id @default(cuid())
  reservationId  String        @unique
  method         PaymentMethod
  tossPaymentKey String?
  amount         Int
  discount       Int           @default(0)
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum CouponType {
  FLAT
  PERCENT
}

model Coupon {
  id           String     @id @default(cuid())
  userId       String
  title        String
  discountType CouponType
  amount       Int
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("coupons")
}

enum PassTier {
  LIGHT
  STANDARD
  PREMIUM
}

model PassSubscription {
  id         String    @id @default(cuid())
  userId     String    @unique
  tier       PassTier
  startedAt  DateTime  @default(now())
  expiresAt  DateTime
  canceledAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pass_subscriptions")
}

model Favorite {
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@map("favorites")
}

model Review {
  id            String   @id @default(cuid())
  reservationId String   @unique
  userId        String
  storeId       String
  rating        Int
  body          String?  @db.Text
  tags          String[] @default([])
  photos        Json     @default("[]")
  createdAt     DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  store       Store       @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@map("reviews")
}

model BeforeAfter {
  id            String   @id @default(cuid())
  reservationId String   @unique
  beforePhoto   String
  afterPhoto    String
  createdAt     DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("before_after")
}

enum InquiryStatus {
  NEW
  CONTACTED
  APPROVED
  REJECTED
}

model PartnerInquiry {
  id          String        @id @default(cuid())
  storeName   String
  contactName String
  phone       String
  address     String?
  message     String?       @db.Text
  status      InquiryStatus @default(NEW)
  memo        String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("partner_inquiries")
}

// ─────────────────────────────────────────────────────────────
// 콘텐츠 (서비스 관리자가 편집)
// ─────────────────────────────────────────────────────────────

model HomeHero {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  subtitle  String?
  title     String
  imageUrl  String
  linkHref  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("home_heroes")
}

model Notice {
  id          String    @id @default(cuid())
  title       String
  body        String    @db.Text
  pinned      Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("notices")
}

model Faq {
  id        String   @id @default(cuid())
  category  String?  // 예약, 결제, 할인패스 등
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("faqs")
}

model Post {
  id          String   @id @default(cuid())
  title       String
  body        String   @db.Text
  authorName  String
  category    String?
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("posts")
}

model SiteEvent {
  id        String   @id @default(cuid())
  kind      String   // 'page_view' | 'signup' | 'reservation' | 'inquiry'
  path      String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([kind])
  @@index([createdAt])
  @@map("site_events")
}
